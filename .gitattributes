# Auto detect text files and normalize line endings
* text=auto

# Explicit text files
*.go text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.mod text eol=lf
*.sum text eol=lf
*.sh text eol=lf
Makefile text eol=lf
Dockerfile text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
